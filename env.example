# Copy to .env and customize
# Browser profile
STEALTH_PROFILE_DIR=profiles/default
STEALTH_HEADLESS=false
STEALTH_OS_TARGET=windows
STEALTH_LOCALE=pt-BR,pt
STEALTH_WINDOW=1366,768

# Stealth options
STEALTH_BLOCK_WEBRTC=true
STEALTH_HUMANIZE=true

# Proxy (optional)
# STEALTH_PROXY_SERVER=socks5://127.0.0.1:1080
# STEALTH_PROXY_USERNAME=
# STEALTH_PROXY_PASSWORD=
